# Contributor: Kenny Root <kenny@the-b.org>
# Maintainer: Kenny Root <kenny@the-b.org>
pkgname=utc-milter
pkgver=0.1.0
pkgrel=0
pkgdesc="Postfix milter that normalizes Date headers to UTC"
url="https://github.com/kruton/utc-milter"
arch="all"
license="BSD-2-Clause"
options="net"
makedepends="go>=1.25"
subpackages="$pkgname-openrc"
source="$pkgname-$pkgver.tar.gz::https://github.com/kruton/utc-milter/archive/refs/tags/v$pkgver.tar.gz
	$pkgname.initd
	$pkgname.confd
	"
builddir="$srcdir/$pkgname-$pkgver"

export CGO_ENABLED=0
export GOFLAGS="$GOFLAGS -trimpath -mod=readonly"

build() {
	go build \
		-ldflags "-s -w -X main.version=$pkgver-r$pkgrel" \
		-o utc-milter ./cmd/utc-milter
}

check() {
	go test ./...
}

package() {
	install -Dm755 utc-milter "$pkgdir"/usr/sbin/utc-milter
	install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/utc-milter
	install -Dm644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/utc-milter
	install -Dm644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}

sha512sums="
SKIP  utc-milter-0.1.0.tar.gz
SKIP  utc-milter.initd
SKIP  utc-milter.confd
"
